  "item": [
    {
      "name": "01 - Login admin",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('admin login returns 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('admin token exists', () => pm.expect(json.token).to.be.a('string').and.not.empty);",
              "pm.test('admin role is ADMIN', () => pm.expect(json.role).to.eql('ADMIN'));",
              "pm.collectionVariables.set('adminToken', json.token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      }
    },
    {
