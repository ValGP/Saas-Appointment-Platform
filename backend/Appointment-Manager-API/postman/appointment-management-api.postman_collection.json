      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const runId = pm.collectionVariables.get('runId') || Date.now().toString();",
              "pm.collectionVariables.set('runId', runId);",
              "pm.collectionVariables.set('clientAEmail', `client.a.${runId}@email.com`);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('client A registration returns 201', () => pm.response.to.have.status(201));",
              "const json = pm.response.json();",
              "pm.test('client A role is CLIENT', () => pm.expect(json.role).to.eql('CLIENT'));",
              "pm.collectionVariables.set('clientAToken', json.token);",
              "pm.collectionVariables.set('clientAId', json.userId);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
