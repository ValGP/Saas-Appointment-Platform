        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"Client A\",\n  \"email\": \"{{clientAEmail}}\",\n  \"password\": \"password123\",\n  \"phone\": \"123456\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "register"
